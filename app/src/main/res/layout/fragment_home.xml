<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicio"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_centerVertical="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:padding="0dp"
            app:icon="@drawable/account_circle"
            app:iconSize="40dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/tvWelcomeMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bienvenido"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:textAlignment="center"
                android:layout_marginBottom="8dp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sistema de Registro de Cumplimiento"
                android:textSize="14sp"
                android:textColor="#888"
                android:layout_gravity="center"
                android:textAlignment="center"
                android:layout_marginBottom="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToDemerits"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Deméritos"
                    android:textSize="14sp"
                    android:paddingVertical="12dp"
                    android:layout_marginEnd="6dp"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/problem"
                    app:iconSize="20dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.MaterialComponents.Button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToStudents"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Alumnos"
                    android:textSize="14sp"
                    android:paddingVertical="12dp"
                    android:layout_marginStart="6dp"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/school"
                    app:iconSize="20dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <!-- Statistics Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estadísticas de Alumnos"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- School Selector for Admins -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSchoolSelector"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:hintEnabled="false">
                <AutoCompleteTextView
                    android:id="@+id/spinnerSchoolSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="false"
                    android:hint="Seleccionar Escuela"
                    android:padding="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Current School Chart -->
            <TextView
                android:id="@+id/tvSchoolChartTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mi Escuela"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            
            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/chartSchool"
                android:layout_width="match_parent"
                android:layout_height="60dp" />

            <!-- Custom Legend for School Chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp">
                
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@color/brand_primary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin Deméritos"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginEnd="16dp" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@color/brand_tertiary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Con Deméritos"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

            <!-- Global Chart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estadísticas Globales"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            
            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/chartGlobal"
                android:layout_width="match_parent"
                android:layout_height="60dp" />

            <!-- Custom Legend for Global Chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp">
                
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@color/brand_primary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin Deméritos"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginEnd="16dp" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@color/brand_tertiary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Con Deméritos"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>