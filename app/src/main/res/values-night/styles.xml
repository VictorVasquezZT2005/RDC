<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Dark Mode application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Palette Colors for Dark Mode -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/dark_background</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorAccent">@color/brand_tertiary</item>
        <item name="colorError">@color/brand_tertiary</item>

        <!-- Unified background for a seamless look -->
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_background</item>
        <item name="colorOnSurface">@color/dark_on_surface</item>

        <!-- UI Components Styles -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="floatingActionButtonStyle">@style/Widget.App.FAB</item>
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNav</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
        
        <!-- System bars tinting unified -->
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Dialog Styles -->
        <item name="materialAlertDialogTheme">@style/Widget.App.MaterialAlertDialog</item>
    </style>

    <!-- Custom Dialog Style -->
    <style name="Widget.App.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Dialog</item>
    </style>

    <style name="ShapeAppearance.App.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <!-- Base styles for inheritance -->
    <style name="Widget.App" parent="" />

    <!-- Custom Button Style (Dark) -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Custom FAB Style (Dark) -->
    <style name="Widget.App.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">?attr/colorAccent</item>
        <item name="tint">@color/black</item>
        <item name="android:textColor">@color/black</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.FAB</item>
    </style>

    <style name="ShapeAppearance.App" parent="" />

    <style name="ShapeAppearance.App.FAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Custom Bottom Navigation (Dark Unified) -->
    <style name="Widget.App.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/dark_background</item>
        <item name="itemIconTint">@color/brand_primary</item>
        <item name="itemTextColor">@color/brand_primary</item>
        <item name="elevation">0dp</item> <!-- Removed elevation for perfect blend -->
    </style>

    <!-- TextInputLayout Style (Dark) -->
    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="android:textColorHint">@color/dark_on_surface_variant</item>
        <item name="boxBackgroundColor">@color/dark_surface_variant</item>
    </style>

    <!-- Outlined Button Style (Dark) -->
    <style name="Widget.App.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

</resources>